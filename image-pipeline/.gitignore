# ==============================================================================
# TERRAFORM
# ==============================================================================

# Local .terraform directories (provider plugins, modules cache)
**/.terraform/
**/.terraform.lock.hcl

# Terraform state files — NEVER commit these (contain sensitive data)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files
*.tfplan
*.plan

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variable files that may contain secrets
# ⚠️  Keep environments/**/*.tfvars in version control if they are non-secret.
#     Uncomment the lines below if your tfvars contain sensitive values.
# *.tfvars
# *.tfvars.json

# Generated Terraform docs
.terraform-docs.yml

# ==============================================================================
# AWS CREDENTIALS & SECRETS
# ==============================================================================

# AWS CLI credentials / config (should never leave your machine)
.aws/
credentials
*.pem
*.key
*.p12
*.pfx

# Environment files that may hold secrets
.env
.env.*
!.env.example

# ==============================================================================
# LAMBDA BUILD ARTIFACTS
# ==============================================================================

# Python Lambda packages
lambda/*/package/
lambda/*/__pycache__/
lambda/*/*.pyc
lambda/*/*.pyo
lambda/*/dist/
lambda/*/build/
lambda/*/.venv/
lambda/*/venv/
lambda/*/env/
lambda/*/.eggs/
lambda/*/*.egg-info/
lambda/*/node_modules/

# Node.js Lambda packages
node_modules/
dist/
build/
*.zip          # deployment zips generated by Terraform/scripts

# ==============================================================================
# PYTHON (if Lambda functions are Python)
# ==============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ==============================================================================
# NODE / JAVASCRIPT (if Lambda functions are Node.js)
# ==============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
*.tsbuildinfo

# ==============================================================================
# IDE / EDITOR
# ==============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ==============================================================================
# OS FILES
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ==============================================================================
# MISC / TOOLING
# ==============================================================================

# Checkov / tfsec / tflint reports
.checkov/
tfsec-results.json
tflint-report.json

# Pre-commit hooks cache
.pre-commit-cache/

# direnv
.envrc

# Logs
*.log
logs/
